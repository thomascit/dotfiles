#!/usr/bin/env bash
# ssh-fzf: fzf picker for SSH hosts defined in ~/.ssh/config

config="${HOME}/.ssh/config"

host=$(
  grep -E '^Host ' "$config" |
    awk '{print $2}' |
    grep -v '^\*$' |
    fzf \
      --prompt='ssh > ' \
      --height=100% \
      --border=block \
      --color=border:#44475a \
      --no-preview
)

[[ -n "$host" ]] && exec ssh "$host"
