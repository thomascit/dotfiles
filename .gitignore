.DS_Store
*.swp
*.swo
*~
.netrwhist
userstate.cbor
todo.md

# Fish-specific
fish/.config/fish/fish_variables
fish/.config/fish/fishd.*

# Tmux plugins (managed by TPM)
tmux/.config/tmux/plugins/*
!tmux/.config/tmux/plugins/.gitkeep

# Neovim state
nvim/.config/nvim/.netrwhist
nvim/.config/nvim/plugin/
nvim/.config/nvim/lazy-lock.json

# Yazi plugins and flavors (managed by ya pkg, tracked via package.toml)
yazi/.config/yazi/plugins/*
!yazi/.config/yazi/plugins/.gitkeep
# Custom plugins (not managed by ya pkg)
!yazi/.config/yazi/plugins/folder-rules.yazi/
!yazi/.config/yazi/plugins/smart-switch.yazi/
yazi/.config/yazi/flavors/*
!yazi/.config/yazi/flavors/.gitkeep

# Secrets / sensitive files
.zenv
*.env
*.pem
*.key
id_rsa
id_ed25519
.netrc
*_secret*
*credentials*

